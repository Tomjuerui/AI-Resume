# ── LLM Provider ──
# Supported: openai | deepseek | qianwen
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=               # Leave empty to use provider default

# ── DeepSeek ──
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-xxx
# Default model: deepseek-chat (or deepseek-reasoner for R1)

# ── QianWen (DashScope) ──
# LLM_PROVIDER=qianwen
# LLM_API_KEY=sk-xxx
# Default model: qwen-plus (or qwen-turbo / qwen-max)

# ── Redis Configuration (Alibaba Cloud KVStore) ──
REDIS_DSN=redis://localhost:6379/0
REDIS_PASSWORD=

# ── OSS Configuration (Alibaba Cloud Object Storage) ──
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# ── App Configuration ──
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_SIZE_MB=10
